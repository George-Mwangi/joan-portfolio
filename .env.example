# ============================================================
# JOAN MWANGI PORTFOLIO – ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# DATABASE (Required)
# Get a free PostgreSQL URL from https://neon.tech
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ------------------------------------------------------------
# AUTH (Required)
# Generate a strong secret: openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="your-super-secret-key-min-32-chars"
AUTH_URL="http://localhost:3000"

# Default admin password (change after first login!)
ADMIN_PASSWORD="Admin@2024!"

# ------------------------------------------------------------
# SITE CONFIG (Required for SEO)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://joanmwangi.vercel.app"
NEXT_PUBLIC_SITE_NAME="Joan Mwangi Portfolio"

# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_VERIFICATION=""

# ------------------------------------------------------------
# EMAIL (Optional – for contact form notifications)
# Using Gmail SMTP as example; use Resend/Postmark in prod
# ------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
CONTACT_EMAIL="joanivymwangi@gmail.com"

# ------------------------------------------------------------
# FILE STORAGE (Optional – for CV and image uploads)
# Start with local, upgrade to S3 later
# Using UploadThing for serverless-friendly uploads
# ------------------------------------------------------------
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# AWS S3 (upgrade path from UploadThing)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="af-south-1"
# AWS_S3_BUCKET="joan-mwangi-portfolio"

# ------------------------------------------------------------
# ANALYTICS (Optional)
# ------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
